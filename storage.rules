rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Permit authenticated read and write access to the backups/ directory
    match /backups/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    // Permit authenticated read and write access to the simulated/ directory (used for uploads)
    match /simulated/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
